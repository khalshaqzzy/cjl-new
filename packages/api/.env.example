ADMIN_PASSWORD_HASH=
APP_TIMEZONE=Asia/Jakarta
ADMIN_ORIGIN=http://localhost:3001
PUBLIC_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000
WA_FAIL_MODE=never
