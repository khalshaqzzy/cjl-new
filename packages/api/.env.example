APP_ENV=local
RELEASE_SHA=local-dev
LOG_LEVEL=info
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/cjlaundry
SESSION_SECRET=replace-me
SESSION_COOKIE_SECURE=false
TRUST_PROXY=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Optional in hosted environments. If set, it overrides ADMIN_PASSWORD for bootstrap seeding.
ADMIN_PASSWORD_HASH=
APP_TIMEZONE=Asia/Jakarta
ADMIN_ORIGIN=http://localhost:3001
PUBLIC_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000
WHATSAPP_ENABLED=false
WHATSAPP_GATEWAY_URL=http://localhost:4100
WHATSAPP_GATEWAY_TOKEN=cjlaundry-whatsapp-internal-token
WHATSAPP_AUTH_DIR=./.whatsapp-auth
WHATSAPP_CHROMIUM_EXECUTABLE_PATH=
WA_FAIL_MODE=never
