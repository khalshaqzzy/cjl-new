{
  "name": "cjl-new",
  "private": true,
  "workspaces": [
    "app/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @cjl/contracts && npm run build --workspace @cjl/api && npm run build --workspace @cjl/whatsapp-gateway && npm run build --workspace @cjl/admin-web && npm run build --workspace @cjl/public-web",
    "build:contracts": "npm run build --workspace @cjl/contracts",
    "build:api": "npm run build --workspace @cjl/api",
    "build:whatsapp": "npm run build --workspace @cjl/whatsapp-gateway",
    "build:admin": "npm run build --workspace @cjl/admin-web",
    "build:public": "npm run build --workspace @cjl/public-web",
    "dev:api": "npm run dev --workspace @cjl/api",
    "dev:whatsapp": "npm run dev --workspace @cjl/whatsapp-gateway",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down -v --remove-orphans",
    "pretest:backend": "npm run build:contracts",
    "test:backend": "node --test --import tsx packages/api/test/integration.test.ts",
    "pretest:e2e": "npm run build:contracts",
    "test:e2e": "playwright test",
    "test": "npm run test:backend && npm run test:e2e",
    "test:serve:api": "tsx scripts/testing/start-api.ts",
    "test:serve:admin": "node scripts/testing/start-admin.mjs",
    "test:serve:public": "node scripts/testing/start-public.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "cookie-signature": "^1.2.2",
    "mongodb-memory-server": "^10.4.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "wait-on": "^9.0.4"
  }
}
