APP_ENV=production
COMPOSE_PROJECT_NAME=cjl-production
SHARED_DIR=/opt/cjl/production/shared
ADMIN_DOMAIN=admin.cjlaundry.site
PUBLIC_DOMAIN=cjlaundry.site
API_DOMAIN=api.cjlaundry.site
CADDY_EMAIL=replace-me@example.com
APP_TIMEZONE=Asia/Jakarta
MONGO_ROOT_USERNAME=replace-me
MONGO_ROOT_PASSWORD=replace-me
MONGO_REPLICA_KEY=replaceMeWithALongRandomAlphaNumericSecret
MONGO_DATABASE=cjlaundry
SESSION_SECRET=replace-me
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD_HASH=replace-me
WHATSAPP_ENABLED=true
WHATSAPP_GATEWAY_TOKEN=replace-me
WHATSAPP_AUTH_DIR=/data/auth
WA_FAIL_MODE=never
